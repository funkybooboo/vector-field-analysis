# Copy this file to .env and fill in your values.
# Source once per shell session before running any scripts:
#   source .env
# All configurable values live here -- scripts have no hardcoded defaults.

# -----------------------------------------------------------------------
# Local runs -- used by mise tasks (demo, run:analyzer, run:analyzer:mpi, visualize:streams)
# -----------------------------------------------------------------------

# Config stem to use for mise tasks (visualize, stats, demo, etc.).
# Must match a filename in configs/ without the .toml extension.
export STEM=karman_street_128x64

# Number of MPI ranks for local benchmark runs.
# Set to 1 to skip MPI and run shared-memory solvers only.
export MPI_RANKS=$(nproc)

# Thread count for OpenMP and pthreads solvers.
# 0 = auto-detect via hardware_concurrency() at runtime (env var is ignored when 0).
# When solver = "all" with MPI active, threads are automatically aligned to MPI_RANKS.
export ANALYZER_THREADS=0

# Parallel workers for streamline pre-computation in tools/visualize.py (default: 4).
export VISUALIZER_THREADS=4

# Threads per CUDA block for the cuda solver (default: 256).
export CUDA_BLOCK_SIZE=256

# Threads per CUDA block for the cuda_full solver (default: 256).
export CUDA_FULL_BLOCK_SIZE=256

# -----------------------------------------------------------------------
# Connection -- used by scripts/local/login.sh, push.sh, pull.sh
# -----------------------------------------------------------------------

# Your CHPC uNID
export CHPC_USER=u0000000

# Login node. Change this to target a different cluster:
#   notchpeak.chpc.utah.edu   primary cluster, A100/V100/P40/2080Ti (requires allocation)
#   kingspeak.chpc.utah.edu   no allocation required, older hardware
#   lonepeak.chpc.utah.edu    account required (lonepeak-gpu), 1080Ti GPUs
#   granite.chpc.utah.edu     newest hardware, H100/L40S (freecycle available)
export CHPC_HOST=notchpeak.chpc.utah.edu

# Absolute path (or ~-relative) to the project on the remote.
# Home dir is shared across all clusters, so this path works everywhere.
# Note: use single quotes so ~ is not expanded by the local shell.
export CHPC_PROJECT='~/projects/vector-field-analysis'

# -----------------------------------------------------------------------
# SLURM -- used by scripts/chpc/gpu-shell.sh, cpu-shell.sh, submit.sh, benchmark.sh
# -----------------------------------------------------------------------

# Account and partition for interactive and batch jobs.
# Change both when switching clusters:
#
#   Cluster      CHPC_PARTITION              CHPC_ACCOUNT
#   notchpeak    notchpeak-gpu               notchpeak-gpu
#   notchpeak    notchpeak-shared-short      notchpeak-shared-short
#   kingspeak    kingspeak-gpu               kingspeak-gpu
#   lonepeak     lonepeak-gpu                lonepeak-gpu
#   granite      granite-gpu-freecycle       granite-gpu-freecycle
#
# Verify your accounts with: sacctmgr show associations user=$USER format=account,partition,cluster
# Use "none" only if the partition truly requires no account.
export CHPC_ACCOUNT=notchpeak-gpu
export CHPC_PARTITION=notchpeak-gpu

# GPU type:count for interactive GPU sessions (gpu-shell.sh) and single-job submission (submit.sh).
# Examples: a100:1  v100:1  2080ti:1  p40:1  1080ti:1  l40s:1  h100:1
export CHPC_GPU=a100:1

# Wall-clock time limit (h:mm:ss). Used by gpu-shell.sh, cpu-shell.sh, submit.sh, and benchmark.sh.
export CHPC_TIME=1:00:00

# CPU cores per job
export CHPC_NTASKS=4

# -----------------------------------------------------------------------
# CUDA -- used by scripts/chpc/check.sh, submit.sh, benchmark.sh, job.sh
# -----------------------------------------------------------------------

# SM architecture for submit.sh. Must match the GPU you intend to run on.
# benchmark.sh ignores this -- it compiles each arch in its CONFIGS automatically.
#
#   GPU           CUDA_ARCH
#   H100 NVL      sm_90
#   L40S          sm_89
#   A100          sm_80
#   V100          sm_70
#   RTX 2080 Ti   sm_75
#   GTX 1080 Ti   sm_61
#   P40           sm_61
export CUDA_ARCH=sm_80

# CUDA module to load on the compute node. Must be compatible with the GPU driver
# on the target cluster. Use `module spider cuda` on the login node to see options.
#
#   Cluster      GPU           CUDA_MODULE
#   notchpeak    A100          cuda/11.6.2
#   lonepeak     GTX 1080 Ti   cuda/12.1.0
#   granite      L40S / H100   cuda/12.1.0
export CUDA_MODULE=cuda/11.6.2

# -----------------------------------------------------------------------
# Job -- used by scripts/chpc/submit.sh and scripts/chpc/benchmark.sh
# -----------------------------------------------------------------------

# SLURM job name prefix (e.g. vfa -> jobs named vfa_a100, etc.)
export JOB_NAME=vfa

# Binary to compile and run. benchmark.sh stages it as <JOB_BIN>_run in the project root.
# This binary is compiled via CMake on the login node and run on the compute node.
export JOB_BIN=analyzer

# TOML config passed as the first argument to JOB_BIN (relative to project root).
# The analyzer expects a config file here, not a raw HDF5 input dataset.
export JOB_INPUT=configs/source_grid_divergent_512x512.toml

# Base output path (relative to project root). job.sh inserts _<gpu_label> before the
# extension and injects it into a temp TOML config so each run writes a distinct file.
export JOB_OUTPUT=output/streams.h5

# -----------------------------------------------------------------------
# Benchmark -- used by scripts/chpc/benchmark.sh
# -----------------------------------------------------------------------

# Space-separated list of GPU labels to run. Must match labels in the
# CONFIGS array inside benchmark.sh. Leave empty to run all targets.
#
# Examples:
#   BENCHMARK_GPUS="a100"         run only A100
#   BENCHMARK_GPUS="a100 v100"    run A100 and V100
#   BENCHMARK_GPUS=""             run all configured targets
export BENCHMARK_GPUS=""
